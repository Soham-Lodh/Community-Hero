# Gemini is the only AI provider used by this app.
# Quotes are OK, no quotes are OK. Restart npm run dev after changing this file.
GEMINI_API_KEY="your-gemini-key"
GEMINI_MODELS="gemini-2.0-flash-lite,gemini-2.0-flash,gemini-1.5-flash-8b,gemini-1.5-flash"

# Server runtime
PORT="3000"
NODE_ENV="development"
JSON_BODY_LIMIT="8mb"
RATE_LIMIT_MAX="90"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Firebase Configuration
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_DATABASE_ID=""
